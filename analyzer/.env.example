# Choose either "openai" or "google"
LLM_PROVIDER=google

# API Keys
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Model Choices:
# For OpenAI: gpt-4o-mini, gpt-4o
# For Google GenAI: gemini-2.5-flash, gemini-2.5-pro
LLM_MODEL=gemini-2.5-flash

# Concurrency & API Rate Limits
MAX_CONCURRENT_REQUESTS=5
RETRY_ATTEMPTS=5

# Pipeline Settings
CHUNK_SIZE=70
CHUNK_OVERLAP=5

# Files
INPUT_FILE=WhatsApp Chat with מנהלי.ות איקומרס.txt
OUTPUT_FILE=results.csv
